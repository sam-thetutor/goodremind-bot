# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Postgres connection string (any Postgres works; Supabase/Neon/local)
DATABASE_URL=postgresql://user:password@localhost:5432/postgres?schema=public

# Celo RPC endpoint (default: public Forno)
CELO_RPC_URL=https://forno.celo.org

# How often to scan subscriptions, in minutes (default 15)
REMINDER_INTERVAL_MINUTES=15
